---
import BaseLayout from "../layouts/BaseLayout.astro";
import legacyHtml from "../../index.html?raw";

const bodyMatch = legacyHtml.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
const pageHtml = bodyMatch?.[1]
  ?.replace(/<script\b[^>]*src=["'][^"']*script\.js[^"']*["'][\s\S]*?<\/script>/i, "")
  ?.trim() ?? "";
---

<BaseLayout
  title="朴哲勳 | Digital Business Card"
  description="以 LLM 與 大數據 爲基, 研究共同住宅 安全·老朽化·災害脆弱性之計量分析與不動産·住宅政策。"
>
  <Fragment set:html={pageHtml} />

  <script>
    import "../../script.js";
  </script>
</BaseLayout>
